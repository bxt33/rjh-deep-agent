# =============================================
# 环境变量配置 - 复制此文件为 .env 并填写你的 key
# =============================================

# DeepSeek API Key（必填）
# 获取地址：https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# DeepSeek 模型选择（可选，默认 deepseek-chat）
# 可选值：
#   deepseek-chat       → DeepSeek-V3，日常任务首选，价格低
#   deepseek-reasoner   → DeepSeek-R1，复杂推理任务，速度稍慢
DEEPSEEK_MODEL=deepseek-chat

# Tavily 搜索 API Key（demo-search 和 demo-multi-agent 需要）
# 获取地址：https://app.tavily.com/
# 免费额度：每月 1000 次
TAVILY_API_KEY=your_tavily_api_key_here

# 温度参数（可选，默认 0.7）
# 0   = 严谨精确（代码生成推荐）
# 0.7 = 均衡（日常任务推荐）
# 1.0 = 创意发散（内容创作推荐）
DEEPSEEK_TEMPERATURE=0.7
